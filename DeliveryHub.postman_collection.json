{
  "info": {
    "_postman_id": "0a4d0e9c-1b6c-4f1b-9a8f-deliveryhub-api",
    "name": "DeliveryHub Backend API",
    "description": "Import this collection into Postman. Set baseUrl if your server uses another port. Login saves token and refreshToken automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "shipmentId",
      "value": "676f1234567890abcdef1234",
      "type": "string"
    },
    {
      "key": "offerId",
      "value": "676f1234567890abcdef1235",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "676f1234567890abcdef1236",
      "type": "string"
    },
    {
      "key": "revieweeId",
      "value": "676f1234567890abcdef1237",
      "type": "string"
    },
    {
      "key": "ticketId",
      "value": "676f1234567890abcdef1238",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Customer\",\n  \"email\": \"customer@example.com\",\n  \"phone\": \"01012345678\",\n  \"password\": \"Password123\",\n  \"role\": \"customer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.tokens) {",
                  "  pm.collectionVariables.set('token', json.data.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Driver",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Driver\",\n  \"email\": \"driver@example.com\",\n  \"phone\": \"01012345679\",\n  \"password\": \"Password123\",\n  \"role\": \"driver\",\n  \"vehicleType\": \"car\",\n  \"plateNumber\": \"ABC-123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Register Office",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Office Owner\",\n  \"email\": \"office@example.com\",\n  \"phone\": \"01012345670\",\n  \"password\": \"Password123\",\n  \"role\": \"office\",\n  \"businessName\": \"Fast Office\",\n  \"licenseNumber\": \"LIC-12345\",\n  \"officeAddress\": \"Nasr City, Cairo, Egypt\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrPhone\": \"customer@example.com\",\n  \"password\": \"Password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.tokens) {",
                  "  pm.collectionVariables.set('token', json.data.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.tokens) {",
                  "  pm.collectionVariables.set('token', json.data.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"01012345678\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/otp/resend"
          }
        },
